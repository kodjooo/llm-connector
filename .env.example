# Ключ API OpenAI. Получить в кабинете OpenAI для окружения, где разрешен доступ к API.
OPENAI_API_KEY=changeme_openai_api_key
# Токен авторизации gateway. Создать и сохранить в секрете pipeline и gateway.
GATEWAY_AUTH_TOKEN=changeme_gateway_token
# Модель OpenAI по умолчанию для relay, если клиент не передал поле model.
DEFAULT_OPENAI_MODEL=gpt-5-mini
# Уровень логирования сервиса: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO
# Хост и порт приложения внутри контейнера.
APP_HOST=0.0.0.0
APP_PORT=8000
# Таймаут одного запроса к OpenAI в секундах.
OPENAI_TIMEOUT_SECONDS=45
# Максимальное количество попыток вызова OpenAI.
OPENAI_MAX_RETRIES=3
# Паузы между повторами OpenAI через запятую.
OPENAI_RETRY_BACKOFF_SECONDS=1,2,3
# Максимальный размер входного тела запроса в байтах.
REQUEST_PAYLOAD_LIMIT_BYTES=32768
# Лимит запросов на одно IP в окне.
RATE_LIMIT_REQUESTS=60
# Размер окна rate limit в секундах.
RATE_LIMIT_WINDOW_SECONDS=60
# Разрешенные исходные IP через запятую. Оставьте пустым, если ограничение выполняет сеть или reverse proxy.
ALLOWED_SOURCE_IPS=
# Длина excerpt для debug-логов.
DEBUG_LOG_EXCERPT_CHARS=500
# Включение endpoint метрик.
METRICS_ENABLED=true
# DSN Sentry. Получить в проекте Sentry, если используется.
SENTRY_DSN=
